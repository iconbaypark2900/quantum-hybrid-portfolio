# --- Choose ONE pattern for API routing (see docs/VERCEL_TWO_PROJECTS.md) ---
#
# Option A — Direct API (cross-origin): browser calls Project A URL. Set CORS_ORIGINS on Flask to this Next app’s origin.
# NEXT_PUBLIC_API_URL=https://your-api-project.vercel.app
# NEXT_PUBLIC_API_KEY=<same as Flask API_KEY>
#
# Option B — Same-origin proxy: leave NEXT_PUBLIC_API_URL empty; Next rewrites /api/* to API_PROXY_TARGET (set to Project A URL on Vercel; not localhost).
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_API_KEY=<same as Flask API_KEY>
# API_PROXY_TARGET=https://your-api-project.vercel.app
#
# Local dev (Flask on :5000) — often leave NEXT_PUBLIC_* empty and use:
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_KEY=

# Optional: GitHub (or other) base URL for repo file links on Strategy Builder (no trailing path segment after branch).
# Example: https://github.com/org/quantum-hybrid-portfolio/blob/main
NEXT_PUBLIC_REPO_FILE_BASE=

# Default for local `next dev`; on Vercel use Option A or B above (do not leave 127.0.0.1 for production).
API_PROXY_TARGET=http://127.0.0.1:5000
