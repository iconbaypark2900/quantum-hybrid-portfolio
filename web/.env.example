# Browser: leave empty to call same-origin `/api/*` (proxied to Flask via rewrites in dev).
# Split Vercel deploy (two projects): set to the Python API project URL, no trailing slash.
# Example: https://your-api-project.vercel.app
# Then set Flask CORS_ORIGINS on the API project to this Next app’s origin.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_KEY=

# Optional: GitHub (or other) base URL for repo file links on Strategy Builder (no trailing path segment after branch).
# Example: https://github.com/org/quantum-hybrid-portfolio/blob/main
NEXT_PUBLIC_REPO_FILE_BASE=

# Target for Next.js rewrites (`/api/*` → Flask). Local dev default; on Vercel UI project use NEXT_PUBLIC_API_URL instead.
API_PROXY_TARGET=http://127.0.0.1:5000
