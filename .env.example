# Quantum Hybrid Portfolio - Environment Configuration
# Copy this file to .env and update values for your environment

# =============================================================================
# Application Settings
# =============================================================================
FLASK_ENV=production
LOG_LEVEL=INFO
# LOG_FORMAT=json | console (json for prod, console for dev)
PORT=5000

# =============================================================================
# Security & Authentication
# =============================================================================
# Generate secure random strings for production (e.g., openssl rand -hex 32)
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-in-production

# API Key Configuration
API_KEY=
API_KEY_REQUIRED=false
ADMIN_API_KEY=change-this-in-production

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL (production)
DATABASE_URL=postgresql://quantum:password@localhost:5432/quantum_portfolio
DB_PASSWORD=password

# SQLite (development/testing)
# DATABASE_URL=sqlite:///dev_portfolio.db

# Staging/Development overrides
STAGING_DATABASE_URL=postgresql://user:pass@localhost/staging
DEV_DATABASE_URL=sqlite:///dev_portfolio.db

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
RATELIMIT_STORAGE_URL=redis://localhost:6379/1

# =============================================================================
# Rate Limiting
# =============================================================================
RATELIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=100

# =============================================================================
# Portfolio Constraints
# =============================================================================
MAX_ASSETS=100
MAX_EVOLUTION_TIME=50
QUANTUM_COMPUTE_TIMEOUT=30

# =============================================================================
# Market Data Providers
# =============================================================================
# Primary provider: tiingo (recommended), yfinance (legacy), alpaca, polygon
# When TIINGO_API_KEY is set, the provider auto-selects tiingo.
# Set DATA_PROVIDER explicitly to override.
DATA_PROVIDER=tiingo
DATA_PROVIDER_FALLBACK=true

# Tiingo (recommended — requires API key)
# Sign up for free at https://api.tiingo.com
TIINGO_API_KEY=
TIINGO_BASE_URL=https://api.tiingo.com

# When using Tiingo for prices, sector/industry are not on Tiingo's daily meta API.
# Set to yfinance to merge only sector + industry from yfinance (optional extra HTTP).
# Leave unset or empty to keep sector/industry as Unknown without Yahoo calls.
# METADATA_SECTOR_SOURCE=yfinance

# yfinance (legacy fallback — no API key required, but rate-limited)
# DEPRECATED: set DATA_PROVIDER=tiingo instead.
YFINANCE_RATE_LIMIT=2000
YFINANCE_TIMEOUT=30

# Alpaca Markets (optional, free tier available)
# Sign up at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://data.alpaca.markets

# Polygon.io (optional, paid, high-quality)
# Sign up at https://polygon.io
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io

# =============================================================================
# AWS Braket Configuration (Optional - for quantum annealing)
# =============================================================================
# Enable/disable Braket integration
BRAKET_ENABLED=false

# Use mock/simulator mode (recommended for development)
BRAKET_USE_MOCK=true
BRAKET_MOCK_DELAY_MS=500

# Real device configuration (optional)
# BRAKET_DEVICE_ARN=arn:aws:braket:us-east-1::device/qpu/d-wave/Advantage_system6
BRAKET_S3_BUCKET=your-bucket-name-for-results
BRAKET_AWS_REGION=us-east-1
BRAKET_SHOTS=100
BRAKET_TIMEOUT=300

# =============================================================================
# Caching
# =============================================================================
CACHE_TTL=3600

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# Monitoring & Logging
# =============================================================================
SENTRY_DSN=
LOG_FORMAT=console

# IBM VQE hardware limits (reduce to control credit usage)
# IBM_VQE_MAX_RESTARTS=2
# IBM_VQE_MAX_ITER=25

# =============================================================================
# Hugging Face Spaces (Optional)
# =============================================================================
# HF_SPACES=1

# =============================================================================
# Job Processing
# =============================================================================
JOB_WORKERS=4

# =============================================================================
# Next.js web app (web/) — see also web/.env.local
# =============================================================================
# Browser-exposed vars must use NEXT_PUBLIC_ prefix. Used by web/src/lib/api.ts.
NEXT_PUBLIC_API_URL=
# Optional; sent as X-API-Key from the browser if set (avoid for public deployments).
NEXT_PUBLIC_API_KEY=
# Optional (Flask API / Vercel Project A): public URL of the Next dashboard (Project B).
# If set, GET / on the API returns JSON with a "dashboard" field pointing here.
# Example: https://<next-project>.vercel.app — see docs/VERCEL_TWO_PROJECTS.md
DASHBOARD_PUBLIC_URL=
# Optional: server-only base URL for Next.js Route Handlers / server fetch (if added later)
# API_URL=http://127.0.0.1:5000

# =============================================================================
# Production-Specific Settings
# =============================================================================
# For production deployments, also set:
# - SECRET_KEY: Use a strong random string
# - JWT_SECRET_KEY: Use a strong random string
# - DATABASE_URL: Point to your production database
# - REDIS_HOST: Point to your Redis instance
# - ADMIN_API_KEY: Use a strong random string for admin operations
# - API_KEY_REQUIRED=true: Enable API key validation
# - SENTRY_DSN: Add your Sentry DSN for error tracking
