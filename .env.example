# ─── Quantum Portfolio Lab - Environment Configuration ───
# Copy to .env and fill in values. Never commit .env to git.

# ─── Application ───
FLASK_ENV=development          # development | staging | production
SECRET_KEY=                    # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=                       # API key for authenticating frontend requests

# ─── Database (optional, not required for simulation mode) ───
DATABASE_URL=postgresql://quantum:password@localhost:5432/quantum_portfolio

# ─── Redis (optional, used for caching and rate limiting) ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Rate Limiting ───
RATELIMIT_STORAGE_URL=memory://   # Use redis://localhost:6379/1 in production

# ─── Quantum Computation Limits ───
MAX_ASSETS=100
MAX_REQUESTS_PER_MINUTE=100
QUANTUM_COMPUTE_TIMEOUT=30
MAX_EVOLUTION_TIME=50

# ─── External APIs ───
YFINANCE_RATE_LIMIT=2000
YFINANCE_TIMEOUT=30

# ─── Monitoring (optional) ───
LOG_LEVEL=INFO
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ─── Frontend ───
# REACT_APP_API_URL=http://localhost:5000   # When unset, dev server proxy handles routing

# ─── CORS ───
CORS_ORIGINS=http://localhost:3000   # Comma-separated list of allowed origins
