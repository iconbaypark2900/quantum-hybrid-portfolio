### 5. Update the optimize endpoint payload parsing
The optimize endpoint currently reads QSW-specific params (omega, evolution_time,
evolution_method). Replace with new params:

```python
@app.route('/api/portfolio/optimize', methods=['POST'])
@require_api_key
@limiter.limit("20 per minute")
def optimize_portfolio():
    data = request.json or {}

    # --- Market data (unchanged) ---
    tickers    = data.get('tickers')
    start_date = data.get('start_date')
    end_date   = data.get('end_date')
    returns    = data.get('returns')
    covariance = data.get('covariance')

    # --- Method selection ---
    objective  = data.get('objective', 'hybrid')

    # --- Per-method params ---
    target_return = data.get('target_return')
    K             = data.get('K')
    K_screen      = data.get('K_screen')
    K_select      = data.get('K_select')
    lambda_risk   = float(data.get('lambda_risk', 1.0))
    gamma         = float(data.get('gamma', 8.0))
    n_layers      = int(data.get('n_layers', 3))
    n_restarts    = int(data.get('n_restarts', 8))
    weight_min    = float(data.get('weight_min', 0.005))
    weight_max    = float(data.get('weight_max', 0.30))
    seed          = int(data.get('seed', 42))

    # ... fetch market data if tickers provided (unchanged logic) ...

    result = run_optimization(
        returns=np.array(returns),
        covariance=np.array(covariance),
        objective=objective,
        target_return=target_return,
        asset_names=assets,
        K=K,
        K_screen=K_screen,
        K_select=K_select,
        lambda_risk=lambda_risk,
        gamma=gamma,
        n_layers=n_layers,
        n_restarts=n_restarts,
        weight_min=weight_min,
        weight_max=weight_max,
        seed=seed,
    )

    # Build response (same shape as before)
    holdings = [
        {"name": name, "weight": float(w)}
        for name, w in zip(assets, result.weights)
        if w > 1e-4
    ]

    response = {
        "weights": result.weights.tolist(),
        "holdings": holdings,
        "sharpe_ratio": result.sharpe_ratio,
        "expected_return": result.expected_return,
        "volatility": result.volatility,
        "n_active": result.n_active,
        "objective": result.objective,
        "stage_info": result.stage_info,
    }
    return success_response(response)
```

### 6. Update /api/portfolio/efficient-frontier
```python
from services.portfolio_optimizer import compute_efficient_frontier

# In the endpoint:
frontier = compute_efficient_frontier(
    returns=np.array(returns),
    covariance=np.array(covariance),
