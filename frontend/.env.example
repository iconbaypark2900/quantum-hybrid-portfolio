# Set this when the API runs on a different host/port
# REACT_APP_API_URL=http://localhost:5000

# When unset, the dev server proxy (package.json "proxy") forwards /api to localhost:5000

# Optional: API key for authenticated requests.
# Required if the backend has API_KEY set or API_KEY_REQUIRED=true.
# REACT_APP_API_KEY=your-api-key
